#!/usr/bin/env bash
# profiles/mini — Profile for the mini devbox VM.

# shellcheck source=./common
source "$(dirname "${BASH_SOURCE[0]}")/common"

PROFILE_NAME="mini"

# --- GCP settings ---
GCP_PROJECT="zaeem-dev"
GCP_REGION="us-central1"
GCP_INSTANCE_NAME="zaeem-devbox-mini"

# --- VM hardware ---
VM_MACHINE_TYPE="e2-micro"
VM_DISK_SIZE=10

# --- Features ---
IDLE_TIMER_ENABLED=false
STATIC_IP=false

# --- Firewall: extra TCP ports to open (beyond SSH/22) ---
# Examples: "3000" (dev server), "8080" (proxy), "5432" (postgres)
FIREWALL_ALLOW_PORTS=(
  # "3000"
)
