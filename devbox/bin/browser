#!/usr/bin/env bash
# browser — $BROWSER handler for headless SSH devbox sessions.
# Called by tools (gh, gcloud, etc.) that respect $BROWSER directly.
# The xdg-open shim (~/.local/bin/xdg-open) delegates here for tools
# that call xdg-open instead.
URL="${1:-}"
[[ -n "${DISPLAY:-}" ]] && command -v xdg-open &>/dev/null \
  && exec /usr/bin/xdg-open "$URL"
printf '\n  Open this URL in your browser:\n  %s\n\n' "$URL"
