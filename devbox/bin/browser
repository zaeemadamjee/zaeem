#!/usr/bin/env bash
# browser — BROWSER wrapper for headless SSH devbox sessions.
#
# Tools like gcloud, gh, and tailscale honour the BROWSER env var when
# they need to open an OAuth URL.  In a headless SSH session there is no
# display, so this script prints the URL prominently instead of trying
# (and silently failing) to open a real browser.
#
# If DISPLAY is set (i.e. `rigging gui` is running and you are connected
# via RustDesk), it falls through to xdg-open so the in-VM browser works.

URL="${1:-}"

if [[ -z "$URL" ]]; then
  echo "usage: browser <url>" >&2
  exit 1
fi

# GUI path — delegate to xdg-open when a display is available.
if [[ -n "${DISPLAY:-}" ]] && command -v xdg-open &>/dev/null; then
  exec xdg-open "$URL"
fi

# Headless path — print the URL so it can be opened on the Mac.
printf "\n"
printf "  \033[1;33m⚠  Open this URL in your browser:\033[0m\n"
printf "\n"
printf "  \033[1;36m%s\033[0m\n" "$URL"
printf "\n"
